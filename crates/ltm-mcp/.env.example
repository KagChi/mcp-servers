# LTM-MCP Server Configuration
# Copy this file to .env and fill in your values

# Required: Database connection string
LTM_DATABASE_URL=postgresql://postgres:password@localhost:5432/ltm-mcp

# Required: API key for authentication
LTM_AUTH_API_KEY=your-secret-api-key-here

# Optional: Server host (defaults to 0.0.0.0)
# LTM_SERVER_HOST=0.0.0.0

# Optional: Server port (defaults to 3000)
# LTM_SERVER_PORT=3000

# Optional: Log level (defaults to info)
# LTM_LOG_LEVEL=info
