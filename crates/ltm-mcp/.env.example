# LTM-MCP Server Configuration
# Copy this file to .env and fill in your values

# Required: Database connection string
LTM_DATABASE_URL=postgresql://postgres:password@localhost:5432/ltm-mcp

# Required: API key for authentication
LTM_AUTH_API_KEY=your-secret-api-key-here

# Optional: Server host (defaults to 0.0.0.0)
# LTM_SERVER_HOST=0.0.0.0

# Optional: Server port (defaults to 3000)
# LTM_SERVER_PORT=3000

# Optional: Log level (defaults to info)
# LTM_LOG_LEVEL=info

# ============================================
# Embedding Configuration (Local Rust-Native)
# ============================================

# Optional: Enable/disable automatic embedding generation (defaults to true)
# When disabled, only keyword search works; semantic/hybrid search will be unavailable
# LTM_EMBEDDING_ENABLED=true

# Optional: Embedding model from Hugging Face (defaults to sentence-transformers/all-MiniLM-L6-v2)
# Popular options:
#   - sentence-transformers/all-MiniLM-L6-v2 (384d, 80MB, fast - DEFAULT)
#   - sentence-transformers/all-MiniLM-L12-v2 (384d, 120MB, better quality)
#   - sentence-transformers/all-mpnet-base-v2 (768d, 420MB, best quality)
# LTM_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional: Embedding dimensions (must match your model's output dimensions, defaults to 384)
# IMPORTANT: Changing this requires a database migration to adjust vector column size
# LTM_EMBEDDING_DIMENSIONS=384

# Optional: Model cache directory (defaults to OS-specific cache directory)
# Models are auto-downloaded from Hugging Face on first startup
# Linux: ~/.cache/ltm-mcp/models
# macOS: ~/Library/Caches/ltm-mcp/models
# Windows: C:\Users\<USER>\AppData\Local\ltm-mcp\models
# LTM_EMBEDDING_CACHE_DIR=/custom/path/to/cache
